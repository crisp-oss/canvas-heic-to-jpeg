{
  "include": ["lib/**/*.ts"],
  "compilerOptions": {
    "declaration": true,
    "outDir": "dist/",
    "module": "es2020",
    "target": "es2020",
    "lib": ["es2020", "dom"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["lib/*"]
    }
  }
}
